{
    "name": "jigoku",
    "version": "2.0.0",
    "description": "The server code for Jigoku, a browser based implementation of the Legend of the Five Rings LCG",
    "type": "module",
    "main": "build/server/gamenode/index.js",
    "scripts": {
        "test": "npm run jasmine",
        "jasmine": "tsc -p tsconfig.test.json && cross-env JASMINE_CONFIG_PATH=./jasmine.json DOMAIN=localhost ENVIRONMENT=test GAME_NODE_NAME=test GAME_NODE_SOCKET_IO_PORT=9500 HTTPS=false LOBBY_PORT=4000 LOBBY_WS_URL=ws://localhost:6000 SECRET=testsecret jasmine",
        "lint": "eslint server/ test/server/",
        "typecheck": "tsc --noEmit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jigoku/jigoku.git"
    },
    "keywords": [
        "l5r",
        "legend",
        "of",
        "the",
        "five",
        "rings",
        "cardgame"
    ],
    "author": "Ryan Karetas <ryan@karetas.com>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/jigoku/jigoku/issues"
    },
    "homepage": "https://github.com/jigoku/jigoku#readme",
    "engines": {
        "node": ">=24.0.0"
    },
    "dependencies": {
        "axios": "1.18.0",
        "bcrypt": "6.0.0",
        "cross-env": "10.1.0",
        "jsonwebtoken": "9.0.3",
        "socket.io": "4.8.3",
        "uuid": "14.0.1",
        "winston": "3.19.0",
        "winston-daily-rotate-file": "5.0.0",
        "ws": "8.21.0",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/bcrypt": "6.0.0",
        "@types/jasmine": "6.0.0",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "26.0.0",
        "@types/ws": "8.18.1",
        "@typescript-eslint/eslint-plugin": "8.61.1",
        "@typescript-eslint/parser": "8.61.1",
        "eslint": "10.5.0",
        "eslint-plugin-jasmine": "4.2.2",
        "globals": "17.7.0",
        "jasmine": "6.3.0",
        "prettier": "3.8.4",
        "typescript": "6.0.3"
    },
    "volta": {
        "node": "24.14.0"
    }
}
